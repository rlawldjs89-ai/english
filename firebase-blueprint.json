{
  "entities": {
    "Booking": {
      "title": "Booking",
      "description": "Consultation and lesson booking application",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "applicantName": { "type": "string" },
        "contact": { "type": "string" },
        "relationship": { "type": "string" },
        "studentName": { "type": "string" },
        "studentAge": { "type": "string" },
        "gradeOrJob": { "type": "string" },
        "region": { "type": "string" },
        "currentLevel": { "type": "string" },
        "selectedCourse": { "type": "string" },
        "classType": { "type": "string" },
        "preferredDate": { "type": "string" },
        "preferredTimeSlot": { "type": "string" },
        "reason": { "type": "string" },
        "goals": { "type": "string" },
        "preferredTeacherGender": { "type": "string" },
        "status": { "type": "string" },
        "trialDate": { "type": "string" },
        "trialTime": { "type": "string" },
        "teacherId": { "type": "string" },
        "createdAt": { "type": "string" },
        "adminMemo": { "type": "string" }
      },
      "required": ["id", "applicantName", "contact"]
    },
    "UserProfile": {
      "title": "UserProfile",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["uid", "email"]
    }
  },
  "firestore": {
    "/bookings/{bookingId}": {
      "schema": { "$ref": "#/entities/Booking" },
      "description": "All consultation and lesson bookings"
    },
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/UserProfile" },
      "description": "Registered user accounts"
    }
  }
}
